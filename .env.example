# .env.example - Environment variables for ChatGPT-to-API proxy

# Required: The session token from chatgpt.com
# Format: eyJhbGciOiJkaXIiLCJlbmMiOiJBMjU2R0NNIn0...
CHATGPT_SESSION_TOKEN=your-session-token-here

# Optional: Server port (default: 3000)
PORT=3000

# Optional: Server host (default: 0.0.0.0)
HOST=0.0.0.0

# Optional: Requires clients to provide this API key in Authorization header
# If not set, the proxy is open to any local client
PROXY_API_KEY=optional-api-key-for-proxy-auth
