# Port for the proxy server to listen on
PORT=3000

# Your ChatGPT Web session token (from '__Secure-next-auth.session-token' cookie)
# Required if you want automatic Access Token fetching.
CHATGPT_SESSION_TOKEN=your_session_token_here

# Optional: Protect this proxy server with a local API key.
# If set, clients must send "Authorization: Bearer <YOUR_PROXY_API_KEY>" to use it.
# Leave blank to disable security (allow anyone on your network to call it).
PROXY_API_KEY=

# Default ChatGPT model slug to use if the client doesn't specify one.
# Options:
# - auto: automatically selects model based on account (recommended)
# - gpt-4o: forces GPT-4o
# - gpt-4: forces GPT-4
DEFAULT_MODEL=auto

# Supabase project hosting the chatgpt schema (api_keys, request_logs, etc.).
# When unset, the proxy falls back to PROXY_API_KEY-only auth with no logging.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
